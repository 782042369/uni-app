    {
      "path": "pages/index/index",
      "type": "home",
      "name": "home",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "首页"
      }
    },
    // #endif
    {
      "path": "pages/index/index",
      "type": "home",
      "name": "index",
      "layout": "tabbar",
      "style": {
        "navigationStyle": "custom"
      }
    },
    // #ifdef APP || APP-HARMONY
    {
      "path": "pages/about/index",
